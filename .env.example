# Shopify Admin API credentials
# Copy this file to .env (git-ignored) and fill in real values.
# Never commit .env or paste credentials into issue comments / chat.
#
# Preferred path for Dev Dashboard apps:
# exchange client credentials for a 24h Admin API access token at runtime.
# Official Shopify docs use SHOPIFY_CLIENT_ID / SHOPIFY_CLIENT_SECRET.
# This repo also accepts SHOPIFY_CLINET_ID / SHOPIFY_SECRET temporarily as
# compatibility aliases for existing secret-manager naming.

SHOPIFY_STORE_DOMAIN=copper-teaware.myshopify.com
SHOPIFY_CLIENT_ID=replace_with_real_client_id
SHOPIFY_CLIENT_SECRET=replace_with_real_client_secret

# Optional compatibility aliases if your runtime currently uses them:
# SHOPIFY_CLINET_ID=replace_with_real_client_id
# SHOPIFY_SECRET=replace_with_real_client_secret

# Optional legacy fallback only if you already have a valid short-lived token.
# Shopify now recommends exchanging client credentials for a token instead.
# SHOPIFY_ADMIN_API_TOKEN=shpat_REPLACE_WITH_REAL_TOKEN

# Required scopes for the exchanged token above:
#   read_products write_products
#   read_themes write_themes
#   read_metafields write_metafields
#   read_online_store_pages write_online_store_pages
#   read_content write_content
